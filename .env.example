# --- Postgres ---
POSTGRES_USER=farmclicker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=farmclicker
DATABASE_URL=postgresql://farmclicker:changeme@postgres:5432/farmclicker?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Server ---
SERVER_PORT=3000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=30d
CORS_ORIGIN=http://localhost:5173

# --- Web (docker build arg only, NOT read by local `vite dev` - see apps/web/.env.example) ---
# Empty = same-origin requests (Caddy routes /api to the server container). Leave empty in prod.
VITE_API_URL=

# --- Caddy ---
DOMAIN=localhost
