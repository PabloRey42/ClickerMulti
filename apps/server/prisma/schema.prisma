generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  username        String            @unique
  passwordHash    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  playerState     PlayerState?
  refreshTokens   RefreshToken[]
  playerGenerators PlayerGenerator[]
}

/// Core farm/idle state for a player: resources, the click-meta currency, and combo momentum.
model PlayerState {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceBalance   BigInt   @default(0)
  affectionBalance  BigInt   @default(0)
  comboStacks       Int      @default(0)
  lastClickAt       DateTime @default(now())
  lastTickAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Catalog of auto-generators (the future "creatures" of jalon 3) a player can buy with resources.
model Generator {
  id               String            @id @default(cuid())
  key              String            @unique
  name             String
  baseCost         BigInt
  costGrowth       Decimal           @db.Decimal(6, 4)
  baseProduction   BigInt
  sortOrder        Int               @default(0)
  playerGenerators PlayerGenerator[]
}

/// How many of a given generator a player owns.
model PlayerGenerator {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatorId String
  generator   Generator @relation(fields: [generatorId], references: [id])
  quantity    Int       @default(0)

  @@unique([userId, generatorId])
  @@index([userId])
}
