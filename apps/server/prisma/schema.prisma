generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                @id @default(cuid())
  email           String                @unique
  username        String                @unique
  passwordHash    String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  playerState     PlayerState?
  refreshTokens   RefreshToken[]
  playerCreatures PlayerCreature[]
  wildEncounter   WildEncounter?
  inventoryItems  PlayerInventoryItem[]
  leagueProgress  PlayerLeagueProgress?
  skillBranches   PlayerSkillBranch[]
  marketListings  MarketListing[]
  questProgress   PlayerQuestProgress[]
}

/// Core player state: gold and combo momentum for the click-to-attack battle loop.
model PlayerState {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goldBalance     BigInt   @default(0)
  comboStacks     Int      @default(0)
  lastClickAt     DateTime @default(now())
  autoHealEnabled Boolean  @default(false)
  /// Both auto-heal and auto-capture are locked behind quest rewards; "Enabled" just
  /// toggles the behavior once "Unlocked" has been granted.
  autoHealUnlocked    Boolean  @default(false)
  autoCaptureEnabled  Boolean  @default(false)
  autoCaptureUnlocked Boolean  @default(false)
  /// Admin-only testing toggle: forces every new wild encounter (and, at the moment it's
  /// switched on, every creature the player already owns) to be shiny.
  forceShinyMode  Boolean  @default(false)
  /// Permanent reward for fully completing the League skill tree: doubles shiny odds on
  /// every future wild encounter roll (see SHINY_CHANCE in game/constants.ts).
  hasShinyCharm   Boolean  @default(false)
  /// Lifetime counters for the Statistiques tab — never decremented/reset, unlike
  /// goldBalance which can be spent.
  totalClicks          Int    @default(0)
  totalPokemonDefeated Int    @default(0)
  totalCaptures        Int    @default(0)
  totalShinyCaptures   Int    @default(0)
  totalGoldEarned      BigInt @default(0)
  totalXpEarned        Int    @default(0)
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// A creature a player owns, caught via a wild encounter. speciesKey references the
/// static SPECIES_CATALOG in @farm-clicker/shared, not a DB row.
model PlayerCreature {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  speciesKey     String
  nickname       String?
  level          Int             @default(1)
  xp             Int             @default(0)
  currentHp      Int
  isOnTeam       Boolean         @default(false)
  isActive       Boolean         @default(false)
  isShiny        Boolean         @default(false)
  caughtAt       DateTime        @default(now())
  marketListings MarketListing[]

  @@index([userId])
}

/// The wild creature a player is currently fighting on a route/dungeon (or a League
/// trainer opponent, when isLeagueBattle). At most one per player.
model WildEncounter {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeKey            String
  speciesKey          String
  level               Int
  currentHp           Int
  maxHp               Int
  isShiny             Boolean  @default(false)
  isLeagueBattle      Boolean  @default(false)
  leagueOpponentIndex Int      @default(0)
  startedAt           DateTime @default(now())
}

/// Tracks League progress: rank increases (never resets) each time the whole trainer
/// roster is cleared, and grants unspent specialization points to invest.
model PlayerLeagueProgress {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rank          Int      @default(0)
  unspentPoints Int      @default(0)
  updatedAt     DateTime @updatedAt
}

/// Tiers unlocked per League skill-tree branch (attack/defense/capture/gold/xp — see
/// SkillBranchId in game/skillTree.ts), 0-4 each. Fully maxing every branch (20 points
/// total) grants the player PlayerState.hasShinyCharm.
model PlayerSkillBranch {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch String
  tier   Int    @default(0)

  @@unique([userId, branch])
  @@index([userId])
}

/// Generic per-player item stack (pokéballs today; reusable for future item types).
model PlayerInventoryItem {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemKey  String
  quantity Int    @default(0)

  @@unique([userId, itemKey])
  @@index([userId])
}

enum MarketAssetType {
  ITEM
  CREATURE
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

/// A gold-priced listing for an item stack or a single creature. Items are escrowed
/// (deducted) on listing and refunded on cancel; creatures stay usable by their owner
/// while listed and transfer atomically on sale.
model MarketListing {
  id           String              @id @default(cuid())
  sellerId     String
  seller       User                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerId      String?
  assetType    MarketAssetType
  itemKey      String?
  quantity     Int?
  creatureId   String?
  creature     PlayerCreature?     @relation(fields: [creatureId], references: [id], onDelete: SetNull)
  askGoldPrice BigInt
  status       MarketListingStatus @default(ACTIVE)
  createdAt    DateTime            @default(now())
  soldAt       DateTime?

  @@index([sellerId])
  @@index([status])
}

enum QuestStatus {
  IN_PROGRESS
  READY_TO_CLAIM
  CLAIMED
}

/// Tracks quest progress against the static QUEST_CATALOG in @farm-clicker/shared. A quest
/// must be explicitly accepted from its NPC (one row created here) and only one quest can
/// be IN_PROGRESS/READY_TO_CLAIM per player at a time. Objectives track passively once
/// accepted; hitting every target moves it to READY_TO_CLAIM, and the reward is only
/// granted once the player returns to the NPC and claims it (-> CLAIMED).
model PlayerQuestProgress {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  questKey          String
  status            QuestStatus @default(IN_PROGRESS)
  /// Record<objectiveKey, currentCount>
  objectiveProgress Json        @default("{}")
  startedAt         DateTime    @default(now())
  completedAt       DateTime?

  @@unique([userId, questKey])
  @@index([userId])
}
