generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String                @id @default(cuid())
  email           String                @unique
  username        String                @unique
  passwordHash    String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  playerState     PlayerState?
  refreshTokens   RefreshToken[]
  playerCreatures PlayerCreature[]
  wildEncounter   WildEncounter?
  inventoryItems  PlayerInventoryItem[]
}

/// Core player state: gold and combo momentum for the click-to-attack battle loop.
model PlayerState {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goldBalance BigInt   @default(0)
  comboStacks Int      @default(0)
  lastClickAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// A creature a player owns, caught via a wild encounter. speciesKey references the
/// static SPECIES_CATALOG in @farm-clicker/shared, not a DB row.
model PlayerCreature {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speciesKey String
  nickname   String?
  level      Int      @default(1)
  xp         Int      @default(0)
  currentHp  Int
  isOnTeam   Boolean  @default(false)
  isActive   Boolean  @default(false)
  caughtAt   DateTime @default(now())

  @@index([userId])
}

/// The wild creature a player is currently fighting on a route/dungeon. At most one per player.
model WildEncounter {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeKey   String
  speciesKey String
  level      Int
  currentHp  Int
  maxHp      Int
  startedAt  DateTime @default(now())
}

/// Generic per-player item stack (pokéballs today; reusable for future item types).
model PlayerInventoryItem {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemKey  String
  quantity Int    @default(0)

  @@unique([userId, itemKey])
  @@index([userId])
}
