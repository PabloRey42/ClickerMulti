generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CreatureType {
  FIRE
  WATER
  GRASS
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  username      String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  playerState   PlayerState?
  refreshTokens RefreshToken[]
  creatures     Creature[]
  wildEncounter WildEncounter?
}

model PlayerState {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currencyBalance BigInt   @default(0)
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// A creature blueprint (not owned by anyone) - the wild/catchable form.
model Species {
  id             String          @id @default(cuid())
  name           String          @unique
  type           CreatureType
  baseAttack     Int
  baseHp         Int
  evolutionLevel Int?
  evolvesToId    String?         @unique
  evolvesTo      Species?        @relation("Evolution", fields: [evolvesToId], references: [id])
  evolvesFrom    Species?        @relation("Evolution")
  creatures      Creature[]
  encounters     WildEncounter[]
}

/// A creature instance owned by a player.
model Creature {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speciesId String
  species   Species  @relation(fields: [speciesId], references: [id])
  level     Int      @default(1)
  xp        BigInt   @default(0)
  caughtAt  DateTime @default(now())

  @@index([userId])
}

/// The single wild creature a player is currently fighting. One per player.
model WildEncounter {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  speciesId  String
  species    Species  @relation(fields: [speciesId], references: [id])
  currentHp  BigInt
  maxHp      BigInt
  lastTickAt DateTime @default(now())
}
