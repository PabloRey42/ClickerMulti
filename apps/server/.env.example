# For running the server locally with `pnpm dev:server` (outside Docker), pointing at the
# postgres/redis containers via their host-mapped ports (see docker-compose.yml).
DATABASE_URL=postgresql://farmclicker:changeme@localhost:5432/farmclicker?schema=public
REDIS_URL=redis://localhost:6379
SERVER_PORT=3000
JWT_ACCESS_SECRET=dev-only-access-secret-change-me
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL=30d
CORS_ORIGIN=http://localhost:5173
